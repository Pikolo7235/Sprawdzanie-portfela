<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Base Activity Checker v2 - All Tx</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f6f9; color: #333; margin: 0; padding: 20px; }
        .container { max-width: 700px; margin: 0 auto; background: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1 { color: #0052FF; text-align: center; margin-bottom: 5px; }
        p.subtitle { text-align: center; color: #666; margin-top: 0; font-size: 14px; }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input[type="text"] { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-size: 14px; }
        button { width: 100%; padding: 12px; background-color: #0052FF; color: white; border: none; border-radius: 4px; font-size: 16px; cursor: pointer; font-weight: bold; }
        button:hover { background-color: #003db3; }
        #loading { display: none; text-align: center; font-weight: bold; color: #0052FF; margin-top: 15px; }
        #results { margin-top: 20px; }
        .stats-box { background: #e6f0ff; border: 1px solid #b3d1ff; padding: 15px; border-radius: 6px; margin-bottom: 20px; text-align: center; font-size: 15px; line-height: 1.6; }
        .stats-box strong { color: #0052FF; font-size: 18px; }
        .stats-box .gas-highlight { color: #dc3545; font-size: 18px; }
        .tx-card { background: #f8f9fa; border-left: 5px solid #ccc; padding: 12px; margin-bottom: 10px; border-radius: 0 4px 4px 0; font-size: 13px; }
        .tx-card.wychodzaca { border-left-color: #dc3545; }
        .tx-card.wchodzaca { border-left-color: #28a745; }
        .tx-card.sukces { background-color: #f1fcf4; }
        .tx-card.blad { background-color: #fff5f5; border-left-color: #ff0000; }
        .tx-header { font-weight: bold; margin-bottom: 5px; display: flex; justify-content: space-between; }
        .tx-details span { display: block; margin-bottom: 2px; color: #555; word-break: break-all; }
        .badge { display: inline-block; padding: 2px 6px; border-radius: 4px; font-size: 11px; font-weight: bold; color: white; }
        .badge.in { background-color: #28a745; }
        .badge.out { background-color: #dc3545; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Base Activity Checker v2</h1>
        <p class="subtitle">Pełna analiza portfela bez limitu transakcji w sieci Base</p>
        
        <div class="form-group">
            <label for="addressInput">Adres portfela (0x...):</label>
            <input type="text" id="addressInput" placeholder="Wklej adres portfela Ethereum/Base" value="">
        </div>
        
        <button id="checkBtn">Pobierz całą historię</button>
        
        <div id="loading">Inicjalizacja pobierania danych...</div>
        
        <div id="results"></div>
    </div>

    <script>
        document.getElementById('checkBtn').addEventListener('click', async () => {
            const addressInput = document.getElementById('addressInput').value.trim();
            const loadingDiv = document.getElementById('loading');
            const resultsDiv = document.getElementById('results');
            
            resultsDiv.innerHTML = '';
            
            if (!/^0x[a-fA-F0-9]{40}$/.test(addressInput)) {
                alert('Proszę podać poprawny adres portfela EVM (0x...)');
                return;
            }

            loadingDiv.style.display = 'block';
            loadingDiv.innerText = 'Pobieranie pierwszej paczki danych...';

            let allTxs = [];
            let page = 1;
            const offset = 1000; // Maksymalny dopuszczalny limit dla jednego zapytania API BaseScan
            let hasMore = true;

            try {
                // Pętla do pobierania wszystkich stron z transakcjami bez limitu
                while (hasMore) {
                    loadingDiv.innerText = `Pobieranie transakcji... (Pobrano już: ${allTxs.length})`;
                    
                    const response = await fetch(`https://basescan.org{addressInput}&startblock=0&endblock=99999999&page=${page}&offset=${offset}&sort=desc`);
                    const data = await response.json();

                    if (data.status === '1' && data.result && data.result.length > 0) {
                        allTxs = allTxs.concat(data.result);
                        
                        // Jeśli zwrócono mniej wyników niż limit strony, oznacza to koniec historii
                        if (data.result.length < offset) {
                            hasMore = false;
                        } else {
                            page++;
                            // Krótkie opóźnienie (0.2s), aby uniknąć agresywnego blokowania rate-limit dla darmowego API
                            await new Promise(resolve => setTimeout(resolve, 200)); 
                        }
                    } else {
                        // Brak kolejnych transakcji lub koniec danych
                        hasMore = false;
                    }
                }

                loadingDiv.style.display = 'none';

                if (allTxs.length === 0) {
                    resultsDiv.innerHTML = '<div class="stats-box">Brak znalezionych transakcji dla tego adresu.</div>';
                    return;
                }

                let incomingCount = 0;
                let outgoingCount = 0;
                let totalGasBurnedWei = 0n;

                let txListHtml = '';
                
                allTxs.forEach(tx => {
                    const isIncoming = tx.to.toLowerCase() === addressInput.toLowerCase();
                    
                    const gasUsed = BigInt(tx.gasUsed);
                    const gasPrice = BigInt(tx.gasPrice);
                    const txGasCostWei = gasUsed * gasPrice;
                    const txGasCostEth = (Number(txGasCostWei) / 10**18).toFixed(6);

                    if (isIncoming) {
                        incomingCount++;
                    } else {
                        outgoingCount++;
                        totalGasBurnedWei += txGasCostWei;
                    }

                    const directionBadge = isIncoming ? '<span class="badge in">IN</span>' : '<span class="badge out">OUT</span>';
                    const cardClass = isIncoming ? 'wchodzaca' : 'wychodzaca';
                    const statusClass = tx.isError === '1' ? 'blad' : 'sukces';
                    
                    const valueEth = (parseInt(tx.value) / 10**18).toFixed(6);
                    const date = new Date(parseInt(tx.timeStamp) * 1000).toLocaleString('pl-PL');

                    txListHtml += `
                        <div class="tx-card ${cardClass} ${statusClass}">
                            <div class="tx-header">
                                <span>${directionBadge} Hash: ${tx.hash.substring(0, 14)}...</span>
                                <span>${date}</span>
                            </div>
                            <div class="tx-details">
                                <span><strong>Od:</strong> ${tx.from}</span>
                                <span><strong>Do:</strong> ${tx.to}</span>
                                <span><strong>Wartość:</strong> ${valueEth} ETH</span>
                                <span><strong>Koszt Gasu:</strong> ${txGasCostEth} ETH</span>
                                <span><strong>Status:</strong> ${tx.isError === '1' ? '❌ Błąd transakcji' : '✅ Sukces'}</span>
                            </div>
                        </div>
                    `;
                });

                const totalGasBurnedEth = (Number(totalGasBurnedWei) / 10**18).toFixed(6);

                const statsHtml = `
                    <div class="stats-box">
                        <strong>Podsumowanie CAŁEJ historii transakcji:</strong><br>
                        📊 Wszystkich operacji: <strong>${allTxs.length}</strong><br>
                        📥 Przychodzące: <strong>${incomingCount}</strong> | 📤 Wychodzące: <strong>${outgoingCount}</strong><br>
                        🔥 Łączny spalony gas: <strong class="gas-highlight">${totalGasBurnedEth} ETH</strong>
                    </div>
                `;

                resultsDiv.innerHTML = statsHtml + txListHtml;

            } catch (error) {
                loadingDiv.style.display = 'none';
                resultsDiv.innerHTML = '<div class="stats-box" style="border-color: #dc3545; background: #fff5f5;">Wystąpił błąd podczas pobierania pełnej historii z API BaseScan.</div>';
                console.error(error);
            }
        });
    </script>
</body>
</html>
